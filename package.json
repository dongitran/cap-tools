{
  "name": "sap-tools",
  "displayName": "SAP Tools",
  "description": "All-in-one toolbox for SAP BTP development workflows",
  "version": "0.10.2",
  "publisher": "dongtran",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dongtran/sap-tools"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:sapTools.regionView",
    "onView:sapTools.cfLogsView",
    "onCommand:sapTools.selectSapBtpRegion",
    "onCommand:sapTools.openCfLogsPanel",
    "onCommand:sapTools.runHanaSql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "SAP Tools",
        "properties": {
          "sapCap.currentScope": {
            "type": "object",
            "scope": "application",
            "markdownDescription": "Currently active SAP BTP scope managed by SAP Tools.",
            "properties": {
              "regionCode": {
                "type": "string"
              },
              "orgName": {
                "type": "string"
              },
              "spaceName": {
                "type": "string"
              }
            }
          },
          "sapTools.sharedCapDebugConfig": {
            "type": "object",
            "scope": "application",
            "default": {},
            "markdownDescription": "Shared remote-source hints for artifact export. SAP Tools reads this first and falls back to `cdsDebug.sharedCapDebugConfig` (the CDS Debug extension), so a single configuration serves both extensions.",
            "properties": {
              "remoteRoot": {
                "type": "string",
                "markdownDescription": "Remote source root inside the CF app container used to locate exported artifacts such as `pnpm-lock.yaml`. Use a fixed path like `/home/vcap/app`, or a regex with `regex:<pattern>` or `/pattern/flags`; regex values are resolved per CF app through `cf ssh` (matched against the folders that contain a `package.json`). When unset or unmatched, SAP Tools falls back to the standard `/home/vcap/app` location."
              }
            }
          },
          "sapTools.appFolderMappings": {
            "type": "array",
            "scope": "application",
            "default": [],
            "markdownDescription": "Explicit Cloud Foundry app name → local folder name mappings for the Apps tab service-folder mapping. Use this when a CF app's name differs too much from its local source folder for the automatic `-`↔`_` normalization to find it. `folderName` is a folder *basename* searched recursively (depth ≤ 6) for a folder with that name containing a `package.json`; it has the highest matching priority. SAP Tools merges these with the CDS Debug extension's `cdsDebug.appFolderMappings` (own entries win on conflicting app names), so a single configuration serves both extensions.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["appName", "folderName"],
              "properties": {
                "appName": {
                  "type": "string",
                  "markdownDescription": "Exact Cloud Foundry application name (case-sensitive)."
                },
                "folderName": {
                  "type": "string",
                  "markdownDescription": "Local source folder name (basename) to resolve this app to."
                }
              }
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "sapTools.selectSapBtpRegion",
        "title": "Open Region Menu",
        "category": "SAP Tools"
      },
      {
        "command": "sapTools.openCfLogsPanel",
        "title": "Open CFLogs Panel",
        "category": "SAP Tools"
      },
      {
        "command": "sapTools.runHanaSql",
        "title": "Run HANA SQL",
        "category": "SAP Tools"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sapTools",
          "title": "SAP Tools",
          "icon": "resources/sap-tools.svg"
        }
      ],
      "panel": [
        {
          "id": "sapToolsPanel",
          "title": "SAP Tools",
          "icon": "resources/sap-tools.svg"
        }
      ]
    },
    "views": {
      "sapTools": [
        {
          "id": "sapTools.regionView",
          "name": "SAP Tools",
          "type": "webview"
        }
      ],
      "sapToolsPanel": [
        {
          "id": "sapTools.cfLogsView",
          "name": "CFLogs",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sapTools.openCfLogsPanel",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "true"
      },
      {
        "command": "sapTools.runHanaSql",
        "key": "ctrl+e ctrl+e",
        "mac": "cmd+e cmd+e",
        "when": "editorTextFocus && editorLangId == sql && sapTools.hanaSqlEditor"
      },
      {
        "command": "sapTools.runHanaSql",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && editorLangId == sql && sapTools.hanaSqlEditor"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "sapTools.selectSapBtpRegion"
        },
        {
          "command": "sapTools.openCfLogsPanel"
        },
        {
          "command": "sapTools.runHanaSql"
        }
      ]
    }
  },
  "files": [
    "dist",
    "docs/designs/prototypes/assets",
    "resources",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node ./scripts/vendor-hdb.mjs && node ./scripts/vendor-table-name-formatters.mjs && node ./scripts/vendor-cf-sync.mjs",
    "watch": "tsc -watch -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "cspell": "cspell \"**/*\" --no-progress --no-must-find-files --gitignore",
    "test:unit": "vitest run",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish": "npx @vscode/vsce publish --no-dependencies",
    "publish:pre": "npx @vscode/vsce publish --pre-release --no-dependencies",
    "validate:root": "npm run typecheck && npm run lint && npm run cspell && npm run test:unit",
    "validate:e2e": "npm --prefix e2e run validate",
    "validate": "npm run validate:root && npm run validate:e2e",
    "prepare": "husky",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@saptools/cf-sync": "^0.4.10",
    "change-case": "^5.4.4",
    "hdb": "^2.27.1",
    "wordsninja": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.90.0",
    "cspell": "^8.17.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.1.1"
  }
}
